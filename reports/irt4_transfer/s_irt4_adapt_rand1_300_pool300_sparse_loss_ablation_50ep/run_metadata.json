      "smoke_num_tx": 2,
      "data_samples": 300,
      "fix_samples": 0,
      "num_samples_low": 1,
      "num_samples_high": 301,
      "target_scale": 256
    },
    "model": {
      "class_name": "RadioWNet",
      "inputs": 3,
      "phases": [
        "secondU"
      ]
