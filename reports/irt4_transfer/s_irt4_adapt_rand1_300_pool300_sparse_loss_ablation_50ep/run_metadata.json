      "compare_against": [
        "reports/irt4_adapt/rand1_300_50ep/secondU_test_metrics.json",
        "reports/irt4_adapt/s_irt4_adapt_rand1_300_pool600_sparse_loss/secondU_test_metrics.json"
      ],
      "metrics": [
        "dense_mse",
        "dense_nmse",
        "sparse_point_mse",
        "sparse_point_nmse"
      ],
      "save_prediction_panels": true,
      "measure_runtime": true
    }
