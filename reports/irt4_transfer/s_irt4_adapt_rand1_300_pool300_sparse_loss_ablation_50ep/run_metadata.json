{
  "config": {
    "experiment": {
      "name": "s_irt4_adapt_rand1_300_pool300_sparse_loss_ablation",
      "description": "Stage 3C ablation: RadioUNet_S IRT4 secondU-only adaptation with the corrected sparse loss but the older 300 receiver pool.",
      "seed": 42
    },
    "data": {
      "dataset_dir": "RadioMapSeer/",
      "loader": "RadioUNet_s_sprseIRT4",
      "simulation": "IRT4",
      "city_map": "complete",
